<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us | Casmash Pastry</title>
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' x='50%' font-family='Pacifico, cursive' font-size='90' fill='%23e11d48' text-anchor='middle'>C</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Pacifico&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { colors: { cream: '#fffdf8', dough: '#fde68a', strawberry: '#fb7185', berry: '#e11d48', choco: '#451a03', caramel: '#b45309' }, fontFamily: { sans: ['Nunito', 'sans-serif'], cursive: ['Pacifico', 'cursive'] }, animation: { 'fade-in-up': 'fadeInUp 0.6s ease-out forwards' }, keyframes: { fadeInUp: { '0%': { opacity: '0', transform: 'translateY(15px)' }, '100%': { opacity: '1', transform: 'translateY(0)' } } } } } };
    </script>
</head>
<body class="bg-rose-50 text-choco font-sans antialiased flex flex-col min-h-screen selection:bg-strawberry selection:text-white">

    <nav class="w-full p-6 flex justify-between items-center bg-white/80 backdrop-blur-md border-b border-dough sticky top-0 z-50 shadow-sm">
        <a href="index.html" class="text-3xl font-cursive text-berry tracking-wide">Casmash Pastry</a>
        <div class="gap-8 hidden md:flex items-center font-bold text-lg">
            <a href="index.html" class="text-choco/70 hover:text-berry transition-colors">Home</a>
            <a href="gallery.html" class="text-choco/70 hover:text-berry transition-colors">Gallery</a>
            <a href="order.html" class="text-choco/70 hover:text-berry transition-colors">Request Quote</a>
            <a href="contact.html" class="text-berry border-b-4 border-berry pb-1">Contact</a>
        </div>
    </nav>

    <main class="flex-grow py-20 px-4 animate-fade-in-up">
        <div class="max-w-4xl mx-auto text-center mb-16">
            <h1 class="text-6xl font-cursive text-berry mb-4">Get in Touch</h1>
            <p class="text-choco/80 font-bold text-xl max-w-xl mx-auto">
                Have a question, a custom request, or want to check availability? We would love to hear from you!
            </p>
        </div>

        <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
            <!-- Contact Details Card -->
            <div class="bg-white p-10 rounded-[2.5rem] shadow-xl border-4 border-dough flex flex-col justify-between space-y-8">
                <div>
                    <h3 class="text-3xl font-cursive text-caramel mb-6">Contact Details</h3>
                    <ul class="space-y-6 font-bold text-lg text-choco/80">
                        <li class="flex items-center gap-4">
                            <span class="w-12 h-12 bg-rose-100 rounded-2xl flex items-center justify-center text-berry text-xl">📞</span>
                            <div>
                                <p class="text-sm text-choco/50 uppercase tracking-wider">Phone</p>
                                <a href="tel:+1234567890" class="hover:text-berry transition-colors">+1 (234) 567-8900</a>
                            </div>
                        </li>
                        <li class="flex items-center gap-4">
                            <span class="w-12 h-12 bg-rose-100 rounded-2xl flex items-center justify-center text-berry text-xl">📧</span>
                            <div>
                                <p class="text-sm text-choco/50 uppercase tracking-wider">Email</p>
                                <a href="mailto:hello@casmashpastry.com" class="hover:text-berry transition-colors">hello@casmashpastry.com</a>
                            </div>
                        </li>
                        <li class="flex items-center gap-4">
                            <span class="w-12 h-12 bg-rose-100 rounded-2xl flex items-center justify-center text-berry text-xl">📍</span>
                            <div>
                                <p class="text-sm text-choco/50 uppercase tracking-wider">Bakery Location</p>
                                <p>123 Sweet Street, Pastry Lane</p>
                            </div>
                        </li>
                    </ul>
                </div>
                <div class="bg-cream p-5 rounded-2xl border border-dough">
                    <p class="text-sm font-bold text-choco/70">🕒 <strong class="text-choco">Hours:</strong> Tuesday – Sunday: 8am – 6pm (Closed Mondays)</p>
                </div>
            </div>

            <!-- Quick Inquiry Card -->
            <div class="bg-white p-10 rounded-[2.5rem] shadow-xl border-4 border-dough flex flex-col justify-center text-center space-y-6">
                <h3 class="text-3xl font-cursive text-berry">Ready to Order?</h3>
                <p class="font-bold text-choco/70">For custom celebration cakes and event quotes, our quote request form is the quickest way to get started!</p>
                <a href="order.html" class="inline-block py-5 bg-berry text-white rounded-2xl font-bold text-xl hover:bg-rose-700 transition-all hover:scale-105 shadow-lg">
                    Go to Order Form
                </a>
            </div>
        </div>
    </main>

    <footer class="bg-choco text-cream py-12 text-center mt-auto">
        <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="space-y-3 text-center md:text-left">
                <h3 class="text-3xl font-cursive text-dough">Casmash Pastry</h3>
                <div class="flex justify-center md:justify-start gap-6 pt-2 font-bold">
                    <a href="#" class="hover:text-strawberry transition-colors">TikTok</a>
                    <a href="#" class="hover:text-strawberry transition-colors">Instagram</a>
                </div>
            </div>
            <div class="text-sm font-semibold text-cream/70 text-center md:text-right pt-6 md:pt-0 border-t md:border-t-0 border-white/10 w-full md:w-auto">
                <p>&copy; 2026 Casmash Pastry. All rights reserved.</p>
                <p class="mt-1">Designed and developed by <a href="https://spiderweb.lol" target="_blank" class="text-dough hover:underline font-bold">Spiderweb</a></p>
            </div>
        </div>
    </footer>
</body>
</html>
